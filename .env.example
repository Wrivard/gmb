# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optionnelle : bypass RLS pour les crons. Si absente, les crons se
# rabattent sur le compte de service ci-dessous (auth membre + RLS).
SUPABASE_SERVICE_ROLE_KEY=

# --- Compte de service (crons sans clé service_role) ---
# Compte auth whitelisté dans agency_members; les routes /api/cron/*
# s'y connectent pour opérer sous la RLS membre. Voir décision #16.
CRON_SERVICE_EMAIL=
CRON_SERVICE_PASSWORD=

# --- Google OAuth (connexion agence, scope business.manage) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# --- Couche GBP : mock | real ---
GBP_MODE=mock
# Miroir client-side (badge « MODE DÉMO » dans l'UI) — garder synchronisé avec GBP_MODE
NEXT_PUBLIC_GBP_MODE=mock
# 0 pour désactiver les ~5 % d'échecs simulés du mock
GBP_MOCK_FAILURES=1

# --- AI ---
OPENAI_API_KEY=
# Modèle texte (réponses reviews + posts) — défaut : gpt-4.1-mini
OPENAI_MODEL=
# Modèle image (posts) — défaut : gpt-image-1 (exige une org OpenAI vérifiée)
OPENAI_IMAGE_MODEL=
# Qualité image : low | medium | high — défaut : medium (~0,06 $/image)
OPENAI_IMAGE_QUALITY=
# Repli image si OpenAI absent ou en échec
GEMINI_API_KEY=

# --- Sécurité ---
# 32 bytes hex : openssl rand -hex 32
ENCRYPTION_KEY=
# Protège les routes /api/cron/*
CRON_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Notifications (chantier R3-2 — optionnel, no-op si absent) ---
# Webhook Slack-compatible (incoming webhook) : reçoit alertes + digest
NOTIFY_WEBHOOK_URL=
# OU courriel via Resend (https://resend.com) — les deux peuvent coexister
RESEND_API_KEY=
# Destinataires (séparés par des virgules)
NOTIFY_EMAIL_TO=
# Expéditeur vérifié chez Resend (défaut : onboarding@resend.dev)
NOTIFY_EMAIL_FROM=
